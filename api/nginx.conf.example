server {
    listen 80;
    server_name api-cacti.puskomedia.net.id;
    return 301 https://$host$request_uri; # Force HTTPS
}

server {
    listen 443 ssl http2;
    server_name api-cacti.puskomedia.net.id;

    # Ganti dengan path SSL Let's Encrypt Anda
    ssl_certificate /etc/letsencrypt/live/api-cacti.puskomedia.net.id/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/api-cacti.puskomedia.net.id/privkey.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;

    location / {
        proxy_pass http://127.0.0.1:3000;
        
        # Header proxy forwarding untuk keamanan middleware NodeJS Rate Limiter dan IP Filter
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Host $host;
    }
}
